# Required for live analysis. Never commit a real key.
OPENAI_API_KEY=

# Fail before the API call when the serialized paper registry exceeds this size.
# Increase deliberately for unusually long searchable PDFs.
CLAIMTRACE_MAX_PAPER_CHARS=500000

# Per-request timeout in seconds. ClaimTrace performs two GPT-5.6 calls.
CLAIMTRACE_API_TIMEOUT_SECONDS=240

